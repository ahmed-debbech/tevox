FROM tevox_vase:latest

ARG SFTP_HOSTNAME
ARG SFTP_USERNAME
ARG SFTP_PWD
ARG SFTP_PATH

ENV SFTP_HOSTNAME=${SFTP_HOSTNAME}
ENV SFTP_USERNAME=${SFTP_USERNAME}
ENV SFTP_PWD=${SFTP_PWD}
ENV SFTP_PATH=${SFTP_PATH}

RUN mkdir -p /output

WORKDIR /app

COPY ./upload_service .

CMD ["/go1.24.4/go/bin/go", "run", "."]
